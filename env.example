# Copy to .env and adjust. .env is gitignored — never commit real secrets.

# Where the app pushes OTLP/HTTP metrics (the OTel Collector). The exporter appends
# /v1/metrics. Use localhost from the host; the collector listens on 4318.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Grafana local admin (compose reads these). Local-only defaults; change for anything real.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Postgres + pgvector (compose reads POSTGRES_*; the app reads CLEARWAY_DB_URL). Local-only
# defaults; change for anything real. The app URL must match the compose creds/port.
POSTGRES_USER=clearway
POSTGRES_PASSWORD=clearway
POSTGRES_DB=clearway
CLEARWAY_DB_URL=postgresql://clearway:clearway@localhost:5432/clearway

# LiteLLM → Ollama (host runtime, not in compose). These are read from the process environment;
# when unset they fall back to the same values baked into the client as code defaults, so a bare
# checkout still runs. The embedding model is baked into the corpus_version; switching to a cloud
# embedder is a config change + a full re-embed.
CLEARWAY_OLLAMA_BASE_URL=http://localhost:11434
CLEARWAY_CHAT_MODEL=gemma4:31b
CLEARWAY_EMBED_MODEL=nomic-embed-text

# MCP retrieval server. `clearway mcp-serve` binds HOST:PORT and mounts the streamable-HTTP
# transport at /mcp; the orchestrator's opt-in MCP client and external reuse clients connect at
# CLEARWAY_MCP_URL. Local-only defaults; a long-lived host process, not in compose.
CLEARWAY_MCP_HOST=127.0.0.1
CLEARWAY_MCP_PORT=8848
CLEARWAY_MCP_URL=http://127.0.0.1:8848/mcp
