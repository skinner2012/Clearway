{
  "uid": "clearway-m0-trust",
  "title": "Clearway — Trust Dashboard",
  "tags": ["clearway", "trust"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "5s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Quality — trust metrics (eval/ + T4)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "citation_hallucination_rate (overall)",
      "description": "Fraction of ALL drafted citations that fail L0/L1 validation — verifiable and unverifiable pooled. M1 stratifies this by oracle-verifiability in the row below.",
      "gridPos": { "h": 9, "w": 18, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "citation_hallucination_rate",
          "legendFormat": "{{eval_set_id}} / {{config_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "pointSize": 6, "showPoints": "always" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "current rate (overall)",
      "gridPos": { "h": 9, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "citation_hallucination_rate",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.34 }, { "color": "red", "value": 0.67 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "unverifiable_share (the honest headline)",
      "description": "Fraction of citations with NO automated oracle to check against — axe `incomplete` items → NO_ORACLE → UNVERIFIABLE. Not an error rate: it is the coverage gap the pipeline is honest about, and the number M5 calibration must shrink.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "unverifiable_share",
          "legendFormat": "{{eval_set_id}} / {{config_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "pointSize": 6, "showPoints": "always", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "current unverifiable_share",
      "description": "Share of citations with no automated oracle (higher = more of the answer rests on un-checked judgment). Coloured neutrally: it is a coverage measure, not a pass/fail gauge.",
      "gridPos": { "h": 9, "w": 6, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "unverifiable_share",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "current rate (verifiable subset)",
      "description": "Hallucination rate over ONLY the oracle-verifiable citations (axe `violations`). ~0 by construction — anything above it is a genuine citation fault where an oracle exists to catch it.",
      "gridPos": { "h": 9, "w": 6, "x": 18, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "citation_hallucination_rate_verifiable",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.05 }, { "color": "red", "value": 0.2 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "expert_edit_distance (human-correction signal)",
      "description": "Mean normalized text-edit distance between the drafted remediation and the human-edited one, over drafts a reviewer edited through the HITL gate (T4). 0 = drafts shipped unedited; higher = the model's judgment drifted from the expert's. Only edited reviews contribute.",
      "gridPos": { "h": 9, "w": 18, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "expert_edit_distance",
          "legendFormat": "{{eval_set_id}} / {{config_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "pointSize": 6, "showPoints": "always", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "current expert_edit_distance",
      "description": "Latest mean human-edit distance over edited drafts (0 = no edits needed).",
      "gridPos": { "h": 9, "w": 6, "x": 18, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "expert_edit_distance",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "purple", "value": null } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Accuracy over time — persisted eval_report history (T5, Postgres)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "accuracy over time (per persisted run)",
      "description": "Read from the persisted `eval_report` rows (one per run, keyed by run_id) via the Postgres datasource — the true per-run history Prometheus can't give (its quality gauges carry no run_id, so runs blur together). Each point is one completed run's stored metrics.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "postgres" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT created_at AS \"time\", (report_json::jsonb -> 'metrics' ->> 'citation_hallucination_rate')::float AS \"hallucination_rate\", (report_json::jsonb -> 'metrics' ->> 'unverifiable_share')::float AS \"unverifiable_share\", (report_json::jsonb -> 'metrics' ->> 'expert_edit_distance')::float AS \"expert_edit_distance\" FROM eval_report ORDER BY created_at"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "pointSize": 8, "showPoints": "always", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Operational — the cost of producing the measurement (T2)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "panels": []
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "LLM call latency (mean, s)",
      "description": "Cumulative mean of gen_ai.client.operation.duration — sum/count of the histogram, split by model. Tagged by model so the cloud-vs-local comparison (M4) is data-ready.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "gen_ai_client_operation_duration_seconds_sum / gen_ai_client_operation_duration_seconds_count",
          "legendFormat": "{{gen_ai_request_model}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0, "custom": { "drawStyle": "line", "lineWidth": 2, "showPoints": "always", "pointSize": 6 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "LLM tokens (cumulative, by type)",
      "description": "gen_ai.client.token.usage histogram sum, split by gen_ai.token.type (input/output) and model.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "gen_ai_client_token_usage_sum",
          "legendFormat": "{{gen_ai_token_type}} · {{gen_ai_request_model}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "lineWidth": 2, "showPoints": "always", "pointSize": 6 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "pipeline step retries (by step)",
      "description": "pipeline_step_retries_total — retry attempts beyond the first, per pipeline step (retrieve/draft/validate).",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 47 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_step_retries_total",
          "legendFormat": "{{step}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "showPoints": "always", "pointSize": 6 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "pipeline failures (by step)",
      "description": "pipeline_failures_total — steps that exhausted their retries and failed, per step.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 47 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_failures_total",
          "legendFormat": "{{step}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "showPoints": "always", "pointSize": 6 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "pipeline step duration (mean, s by step)",
      "description": "Cumulative mean of pipeline_step_duration — sum/count of the histogram, per step (includes retries).",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 47 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_step_duration_sum / pipeline_step_duration_count",
          "legendFormat": "{{step}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0, "custom": { "drawStyle": "line", "lineWidth": 2, "showPoints": "always", "pointSize": 6 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "MCP retrieval call latency (mean, s)",
      "description": "Cumulative mean of mcp.client.operation.duration — sum/count of the histogram — for the opt-in over-MCP retrieval path: the cross-boundary tool call's client-observed latency.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 55 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "mcp_client_operation_duration_seconds_sum / mcp_client_operation_duration_seconds_count",
          "legendFormat": "{{gen_ai_tool_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0, "custom": { "drawStyle": "line", "lineWidth": 2, "showPoints": "always", "pointSize": 6 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "MCP retrieval error rate",
      "description": "Fraction of MCP retrieval calls that failed — mcp.client.operation.duration count tagged error.type over the total. 0 while all calls succeed.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 55 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(sum(mcp_client_operation_duration_seconds_count{error_type!=\"\"}) or vector(0)) / sum(mcp_client_operation_duration_seconds_count)",
          "legendFormat": "error rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "showPoints": "always", "pointSize": 6 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 14,
      "type": "text",
      "title": "LLM cost",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 63 },
      "options": {
        "mode": "markdown",
        "content": "**Cost per call is captured on every trace** (`Trace.cost_usd`, priced at the call site in T2) but is **≈ 0 for the local Ollama** models M2 runs against, so there is no live Prometheus cost series to chart yet. It lights up as a real number when cloud LLMs enter the comparison (**M4** routing). The token-usage panel above is the M2 proxy for spend."
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "Judge calibration & confidence — does the system know when it doesn't know?",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 69 },
      "panels": []
    },
    {
      "id": 15,
      "type": "stat",
      "title": "judge κ (judge-vs-human)",
      "description": "Cohen's κ between the LLM judge and the human gold labels on judgment items. Judge-vs-ONE-labeller (not consensus), so do not over-read it. Green at/above the pre-committed 0.6 bar; red below. A snapshot gauge, refreshed only when the calibration is re-emitted.",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 70 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "judge_kappa",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": -1,
          "max": 1,
          "decimals": 3,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 0.6 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 23,
      "type": "stat",
      "title": "judge trusted?",
      "description": "1 iff κ cleared the pre-committed 0.6 bar. Only a trusted judge may score models on non-gold items — the gate M5 depends on.",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 70 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "judge_trusted",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "NOT TRUSTED", "color": "red" }, "1": { "text": "TRUSTED", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 24,
      "type": "stat",
      "title": "raw judge agreement",
      "description": "Raw proportion of drafts where the judge and human verdicts match — reported alongside κ because a small n makes κ fragile.",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 70 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "judge_agreement_rate",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 19,
      "type": "stat",
      "title": "judgment correctness (judge-scored)",
      "description": "Fraction of judgment items the judge scored correct — an ESTIMATE capped by κ, never promoted into the verified count. Distinct from the oracle-verified subset.",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 70 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "judgment_correctness_rate",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "confidence → correctness (per confidence bin)",
      "description": "The calibration curve: for each confidence bin, the drafter's mean self-reported confidence vs. its actual correctness. A calibrated drafter keeps the two lines together; the vertical gap between them IS the miscalibration. The reads predict a single populated bin in [0.8,1.0] — confidence never drops — with correctness far below it (over-confident).",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 76 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "confidence_mean_confidence",
          "legendFormat": "mean confidence [{{bin}}]"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "confidence_correctness",
          "legendFormat": "correctness [{{bin}}]"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "pointSize": 8, "showPoints": "always" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 20,
      "type": "stat",
      "title": "ECE",
      "description": "Expected Calibration Error — the count-weighted average gap between confidence and correctness across bins. Unsigned magnitude of miscalibration; 0 = perfectly calibrated.",
      "gridPos": { "h": 7, "w": 4, "x": 12, "y": 76 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
